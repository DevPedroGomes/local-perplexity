# Environment: "development" or "production"
# In production, CORS is restricted and error messages are sanitized
ENV=development

# LLM Configuration - Primary: Groq (https://console.groq.com)
# Free tier with generous limits, ultra-fast inference
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Alternative models:
# - llama-3.3-70b-versatile (best quality, ~750 tok/s)
# - llama-3.1-70b-versatile (great quality, ~800 tok/s)
# - llama-3.1-8b-instant (faster, ~1300 tok/s)
# - mixtral-8x7b-32768 (good for long context)

# LLM Configuration - Fallback: DeepSeek (https://platform.deepseek.com)
# Cheapest option at $0.07/M input tokens
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# Alternative models:
# - deepseek-chat (V3, fast, cheap)
# - deepseek-reasoner (R1, better reasoning, slower)

# Tavily API (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5

# Session Configuration
MAX_CONCURRENT_SESSIONS=35
SESSION_TIMEOUT_MINUTES=30

# Rate Limiting & Abuse Prevention (per session)
MAX_SEARCHES_PER_SESSION=5
MIN_SECONDS_BETWEEN_SEARCHES=10

# Rate Limiting per IP (prevents session bypass via incognito/localStorage clear)
IP_MAX_SEARCHES_PER_WINDOW=15
IP_WINDOW_SECONDS=3600
IP_MIN_SECONDS_BETWEEN_SEARCHES=8

# CORS (add your frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# LLM Configuration (Groq - https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant
# Alternative models:
# - llama-3.1-70b-versatile (better quality, slower)
# - llama-3.1-8b-instant (faster, good for most tasks)
# - mixtral-8x7b-32768 (good balance)

# Tavily API (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Session Configuration
MAX_CONCURRENT_SESSIONS=35
SESSION_TIMEOUT_MINUTES=30

# Rate Limiting & Abuse Prevention
MAX_SEARCHES_PER_SESSION=5
MIN_SECONDS_BETWEEN_SEARCHES=10

# CORS (add your frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

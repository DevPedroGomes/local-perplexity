# Environment: "development" or "production"
# In production, CORS is restricted and error messages are sanitized
ENV=development

# LLM Configuration - Primary: Cerebras (https://cerebras.ai)
# Free tier: 1M tokens/day, 6x faster than Groq
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama-3.3-70b
# Alternative models:
# - llama-3.3-70b (best quality, 450 tok/s)
# - llama3.1-8b (faster, 1800 tok/s)

# LLM Configuration - Fallback: DeepSeek (https://platform.deepseek.com)
# Cheapest option at $0.07/M input tokens
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# Alternative models:
# - deepseek-chat (V3, fast, cheap)
# - deepseek-reasoner (R1, better reasoning, slower)

# Tavily API (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5

# Session Configuration
MAX_CONCURRENT_SESSIONS=35
SESSION_TIMEOUT_MINUTES=30

# Rate Limiting & Abuse Prevention
MAX_SEARCHES_PER_SESSION=5
MIN_SECONDS_BETWEEN_SEARCHES=10

# CORS (add your frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
